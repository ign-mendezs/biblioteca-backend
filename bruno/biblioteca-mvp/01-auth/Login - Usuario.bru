meta {
  name: Login - Usuario
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "usuario@empresa.com",
    "password": "user123"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    const data = res.getBody();
    bru.setEnvVar("tokenUsuario", data.token);
    console.log("Token de Usuario guardado exitosamente!");
  }
}
