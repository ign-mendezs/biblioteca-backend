meta {
  name: Login - Bibliotecario
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "bibliotecario@empresa.com",
    "password": "admin123"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    const data = res.getBody();
    bru.setEnvVar("tokenBibliotecario", data.token);
    console.log("Token de bibliotecario guardado exitosamente!");
  }
}
