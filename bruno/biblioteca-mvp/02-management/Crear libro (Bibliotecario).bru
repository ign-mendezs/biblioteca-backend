meta {
  name: Crear libro (Bibliotecario)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/management/books
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{tokenBibliotecario}}
  Content-Type: application/json
}

body:json {
  {
    "id": "{{newBookId}}",
    "title": "Clean Architecture",
    "author": "Robert C. Martin"
  }
}
